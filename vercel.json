{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "OPENAI_API_KEY": {
      "description": "OpenAI API Key",
      "required": true
    },
    "HUGGINGFACE_API_KEY": {
      "description": "Hugging Face API Key",
      "required": true
    },
    "NEXT_PUBLIC_APP_URL": {
      "description": "Application URL",
      "required": false
    },
    "MOCK_MODE": {
      "description": "Enable mock mode for testing",
      "required": false
    }
  }
}
